# ─────────────────────────────────
# Docker Compose Environment
# Copy to .env and fill in values
# NEVER commit .env to version control
# ─────────────────────────────────

# MongoDB
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=change_me_strong_root_password
MONGO_APP_USER=app_user
MONGO_APP_PASSWORD=change_me_strong_app_password

# Backend
NODE_ENV=production
JWT_SECRET=change_me_to_at_least_64_random_characters_use_openssl_rand
JWT_EXPIRES_IN=1h
BCRYPT_ROUNDS=12

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5

# Frontend
FRONTEND_PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost
